# QuantWatch 敏感配置模板（可 git 跟踪）
# 复制为 .env 后填入真实凭证

# 飞书机器人 Webhook URL（在飞书群中添加自定义机器人获取）
QUANTWATCH_FEISHU_WEBHOOK=your_webhook_url

# 飞书群名称（Hermes send_message 目标）
QUANTWATCH_FEISHU_GROUP=股海信息

# 去重窗口（小时）：同标的同方向在此窗口内不重复推送
QUANTWATCH_DEDUP_HOURS=4

# ── 以下为预留通知渠道（Phase 2 后续接入） ──
# 邮件通知（QQ 邮箱示例）
QUANTWATCH_EMAIL_SMTP=smtp.qq.com
QUANTWATCH_EMAIL_PORT=587
QUANTWATCH_EMAIL_USER=your@email.com
QUANTWATCH_EMAIL_PASS=your_password

# 企业微信机器人 Webhook
QUANTWATCH_WECHAT_WEBHOOK=your_wechat_webhook

# Telegram Bot Token
QUANTWATCH_TELEGRAM_TOKEN=your_bot_token
